{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchemeDocument",
  "description": "One MSME financing scheme. Must align with core.schema.SchemeDocument.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scheme_id", "name", "administered_by", "scheme_type", "target_segments",
    "loan_range_min", "loan_range_max", "interest_rate_min", "interest_rate_max",
    "collateral_required", "eligibility_vintage_months_min", "eligibility_gst_required",
    "eligibility_sectors_included", "eligibility_sectors_excluded",
    "eligibility_geographic_restriction", "retrieval_text", "official_url",
    "last_verified_date"
  ],
  "properties": {
    "scheme_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "name": {"type": "string", "minLength": 3},
    "administered_by": {"type": "string"},
    "scheme_type": {
      "type": "string",
      "enum": ["term_loan", "working_capital", "credit_guarantee", "subsidy", "composite", "equity"]
    },
    "target_segments": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "loan_range_min": {"type": "number", "minimum": 0},
    "loan_range_max": {"type": "number", "minimum": 0},
    "interest_rate_min": {"type": "number", "minimum": 0, "maximum": 100},
    "interest_rate_max": {"type": "number", "minimum": 0, "maximum": 100},
    "collateral_required": {"type": "boolean"},
    "eligibility_vintage_months_min": {"type": "integer", "minimum": 0},
    "eligibility_gst_required": {"type": "boolean"},
    "eligibility_sectors_included": {
      "type": "array", "items": {"type": "string"},
      "description": "Empty array means all sectors eligible."
    },
    "eligibility_sectors_excluded": {"type": "array", "items": {"type": "string"}},
    "eligibility_geographic_restriction": {
      "type": "string",
      "description": "Empty string means no restriction; else a state/region name."
    },
    "retrieval_text": {"type": "string", "minLength": 20},
    "official_url": {"type": "string", "pattern": "^https?://"},
    "last_verified_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  }
}